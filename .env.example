# Neo4j Aura
NEO4J_URI=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
NEO4J_USER=your-aura-username
NEO4J_PASSWORD=your-aura-password
NEO4J_DATABASE=your-instance-id

# Qdrant Cloud
QDRANT_URL=https://YOUR_CLUSTER.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=governai_ontology
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Customer API (uvicorn)
API_HOST=127.0.0.1
API_PORT=8800
# API_RELOAD=true   # optional; reload can break port binding on Windows

# MongoDB — full URI or user/password + host
MONGO_DB_HOST=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/
MONGO_DB_USER=your-user
MONGO_DB_PASSWORD=your-password
MONGO_DB_NAME=govern-ai-agent
# MONGO_DB_COLLECTION=customers
# MONGO_DISCOVERY_COLLECTION=discovery_sessions

# Discovery Agent (Gemini)
GOOGLE_API_KEY=your-google-api-key
# DISCOVERY_LLM_MODEL=gemini-2.0-flash
# DISCOVERY_DISABLE_LLM=1
# DISCOVERY_DISABLE_LLM=1
