# Neo4j Aura
NEO4J_URI=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
NEO4J_USER=your-aura-username
NEO4J_PASSWORD=your-aura-password
NEO4J_DATABASE=your-instance-id

# Qdrant Cloud
QDRANT_URL=https://YOUR_CLUSTER.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=governai_ontology
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Customer API (uvicorn)
API_HOST=127.0.0.1
API_PORT=8800
# API_RELOAD=true   # optional; reload can break port binding on Windows

# MongoDB — full URI or user/password + host
MONGO_DB_HOST=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/
MONGO_DB_USER=your-user
MONGO_DB_PASSWORD=your-password
MONGO_DB_NAME=govern-ai-agent
# MONGO_DB_COLLECTION=customers
# MONGO_DISCOVERY_COLLECTION=discovery_sessions_v2

# Discovery v2 (Groq — loaded from govern-ai-agent/.env via agent/api/_env.py)
# Create at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
# Primary: Llama 4 Scout (fast). Fallback: Llama 3.3 70B (quality).
DISCOVERY_LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
DISCOVERY_LLM_FALLBACK_MODELS=llama-3.3-70b-versatile
# DISCOVERY_DISABLE_LLM=1

# Phoenix / Arize — link audit test executions to traces (copy from example-agent/.env)
# PHOENIX_API_KEY=your-phoenix-api-key
# PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space
# PHOENIX_PROJECT_NAME=your-project-name

# Customer login (same Mongo customers collection — links discovery, KG, audit)
GOVERN_AUTH_DEMO_EMAIL=root@gov.os
GOVERN_AUTH_DEMO_PASSWORD=governai-dev
GOVERN_AUTH_SECRET=change-me-in-production
GOVERN_AUTH_ALLOW_REGISTER=true
